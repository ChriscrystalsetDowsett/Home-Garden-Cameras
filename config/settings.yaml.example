# Garden Monitor — configuration template
# Copy this file to settings.yaml and edit for your device:
#   cp config/settings.yaml.example config/settings.yaml
#
# settings.yaml is gitignored so each Pi keeps its own local copy.
# git pull will never overwrite your device-specific settings.

server:
  host: "0.0.0.0"      # listen on all interfaces; change to 127.0.0.1 to restrict
  port: 8080
  pi_name: pi3          # unique identifier for this camera node — change per deployment

camera:
  name: "my-pi"                   # identifies this feed — change per device (e.g. "Pi 4 Garden")
  backend: "picamera2"            # "picamera2" for CSI camera modules; "v4l2" for USB webcams
  default_resolution: "1280x720"  # 640x480 | 1280x720 | 1920x1080
  hflip: false                    # flip image horizontally at startup
  vflip: false                    # flip image vertically at startup

paths:
  photos: "data/photos"   # relative to the project root
  videos: "data/videos"   # relative to the project root

# ── Camera schedule ───────────────────────────────────────────────────────────
# Automatically disable the camera stream at night and re-enable in the morning.
# Times are in 24-hour format (HH:MM) in the Pi's local timezone.
# Set enabled to false to turn scheduling off without removing the times.
schedule:
  enabled: false
  camera_off: "21:00"   #  9:00 pm
  camera_on:  "06:00"   #  6:00 am

# ── Dashboard — list of camera Pis to show in the /dashboard grid ─────────────
# Add one entry per camera Pi. Use the Pi's LAN IP — 'localhost' only works if
# the browser is running on that same machine.
cameras:
  - name: "Camera 1"
    host: "192.168.1.101"
    port: 8080
  - name: "Camera 2"
    host: "192.168.1.102"
    port: 8080
  - name: "Camera 3"
    host: "192.168.1.103"
    port: 8080
